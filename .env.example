# ComtradeBench — .env.example
# Copy to `.env` and fill in the keys you need. .env is gitignored.
#
# You do NOT need all four providers. Pick whichever LLM you want to evaluate
# and set REASONING_BACKEND to match: kimi | anthropic | groq | nebius

REASONING_BACKEND=kimi

# ---- Kimi / Moonshot (used for the canonical apples-to-apples run) ----
# International endpoint: https://api.moonshot.ai/v1
# China endpoint:         https://api.moonshot.cn/v1
KIMI_API_KEY=sk-your-moonshot-key-here
KIMI_MODEL=moonshot-v1-128k

# ---- Anthropic (Claude Sonnet 4.6 third-model run) ----
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Groq (Llama 3.3 70B sub-frontier contrast) ----
GROQ_API_KEY=gsk-your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Nebius (optional, DeepSeek / other OAI-compatible models) ----
NEBIUS_API_KEY=
NEBIUS_MODEL=deepseek-ai/DeepSeek-V3-0324

# ---- Agent loop knobs (defaults match the published runs) ----
NUM_ROLLOUTS=1
MAX_REACT_TURNS=2
MAX_CONTEXT_CHARS=100000
MAX_TOKENS=4000
ENABLE_CODE_EXEC=true
